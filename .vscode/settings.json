{
  "cmake.configureOnOpen": false,
  "cmake.sourceDirectory": "${workspaceFolder}",
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.generator": "Ninja",
  "files.associations": {
    "*.h": "c",
    "*.overlay": "dts",
    "*.dts": "dts",
    "*.dtsi": "dts",
    "*.conf": "kconfig",
    "*.defconfig": "kconfig",
    "Kconfig*": "kconfig",
    "*.yml": "yaml",
    "*.yaml": "yaml"
  },
  "files.exclude": {
    "**/build/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/build/**": true,
    "**/.venv/**": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true
  },
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.errorSquiggles": "enabled",
  "cortex-debug.enableTelemetry": false,
  "cortex-debug.showRTOS": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.osx": {
    "ZEPHYR_TOOLCHAIN_VARIANT": "zephyr",
    "ZEPHYR_SDK_INSTALL_DIR": "~/zephyr-sdk-0.16.8"
  },
  "python.defaultInterpreterPath": "./.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "[c]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[dts]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "nrf-connect.toolchain.path": "${nrf-connect.toolchain:2.9.0}",
  "nrf-connect.topdir": "${nrf-connect.sdk:2.9.0}",
  "sonarlint.pathToCompileCommands": "${workspaceFolder}/build/SlimeVR-Tracker-nRF/compile_commands.json"
}
